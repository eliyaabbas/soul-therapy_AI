# ─── Authentication ────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Facebook / Instagram OAuth ───────────────────────────────────────────────
# https://developers.facebook.com → My Apps → Add a Product → Facebook Login
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ─── Apple Sign In ─────────────────────────────────────────────────────────────
# https://developer.apple.com → Certificates, IDs & Profiles → Keys
APPLE_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=
APPLE_KEY_ID=

# ─── Twilio (Phone/SMS OTP) ────────────────────────────────────────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Database (Vercel Postgres) ────────────────────────────────────────────────
# Auto-populated when you connect Vercel Postgres storage
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SoulTherapy
